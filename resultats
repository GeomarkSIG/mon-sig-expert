/* ══════════════════════════════════════════════════════════════════
   MOTEUR DE SÉLECTION DE SCÉNARIO
   Lit les paramètres URL et choisit le scénario le plus proche.
   Scoring : budget (40%) + secteur (35%) + mode (15%) + options (10%)
══════════════════════════════════════════════════════════════════ */
const P = new URLSearchParams(window.location.search);
const secteur  = P.get('secteur')  || '';
const budget   = P.get('budget')   || 'zero';
const mode     = P.get('mode')     || 'simple';
const volume   = P.get('volume')   || 'nsp';
const collab   = P.get('collaboration') || 'nsp';
const souverain= P.get('souverainete') || 'nsp';
const imagerie = P.get('imagerie') || 'nsp';
const terrain  = P.get('terrain')  || 'nsp';
const diffusion= P.get('diffusion')|| 'nsp';
const si_exist = P.get('si_existant') || 'nsp_si';

const NB_USERS_MAP = {solo:1, multi_2_5:3, multi_10:12, nsp:1};
const nbUsers = NB_USERS_MAP[collab] || 1;

// Correspondances scénarios recommandés selon profil
// Matching rule : (budget_groupe, secteur_groupe, options) → score → pick scénario
function matchScore(sc) {
  let score = 0;
  const badge = sc.badge.toLowerCase();

  // Budget matching (40 pts max)
  if (budget === 'zero'       && (badge.includes('gratuit') || badge.includes('0 €') || badge.includes('open source'))) score += 40;
  else if (budget === 'starter_free' && (badge.includes('500') || badge.includes('starter') || badge.includes('< 500'))) score += 40;
  else if (budget === 'inter_pro'    && (badge.includes('1 000') || badge.includes('5 000') || badge.includes('intermédiaire'))) score += 40;
  else if (budget === 'entreprise'   && (badge.includes('+10k') || badge.includes('enterprise') || badge.includes('grande'))) score += 40;
  else if (budget === 'nsp'          && (badge.includes('gratuit') || badge.includes('0 €'))) score += 30;

  // Secteur matching (35 pts max)
  if (secteur === 'ong'         && (badge.includes('ong') || badge.includes('humanit'))) score += 35;
  if (secteur === 'collectivite'&& (badge.includes('collectivité') || badge.includes('territorial'))) score += 35;
  if (secteur === 'etat'        && badge.includes('collectivité')) score += 25;
  if (secteur === 'geometre'    && badge.includes('géomètre')) score += 35;
  if (secteur === 'btp'         && (badge.includes('btp') || badge.includes('géomètre'))) score += 30;
  if (secteur === 'bet_env'     && (badge.includes('environnement') || badge.includes('bet'))) score += 35;
  if (secteur === 'agriculture' && badge.includes('agricult')) score += 35;
  if (secteur === 'energie'     && (badge.includes('énergie') || badge.includes('réseau'))) score += 35;
  if (secteur === 'transport'   && badge.includes('transport')) score += 35;
  if (secteur === 'immobilier'  && badge.includes('immobilier')) score += 35;
  if (secteur === 'geomarketing'&& badge.includes('géomark')) score += 35;
  if (secteur === 'etudiant'    && (badge.includes('recherche') || badge.includes('étudiant') || badge.includes('éducation'))) score += 35;

  // Options expert (15 pts max)
  if (souverain === 'critique'  && badge.includes('air-gapped')) score += 15;
  if (souverain === 'sensible'  && (badge.includes('souveraineté') || badge.includes('france'))) score += 10;
  if (si_exist === 'azure'      && badge.includes('azure')) score += 12;
  if (si_exist === 'aws'        && badge.includes('aws')) score += 12;
  if (si_exist === 'arcgis_si'  && badge.includes('esri')) score += 12;
  if (volume === 'lourd'        && badge.includes('big data')) score += 12;
  if (terrain === 'kobo'        && (badge.includes('terrain') || badge.includes('enquête'))) score += 8;
  if (imagerie === 'drone'      && badge.includes('précision')) score += 8;
  if (mode === 'expert'         && badge.includes('expert')) score += 5;

  // Bonus spéciaux
  if (collab === 'multi_10' && badge.includes('grande')) score += 10;
  if (collab === 'multi_2_5' && badge.includes('équipe')) score += 8;
  if (budget === 'zero' && secteur === 'ong') score += 20; // Fort bonus combiné
  if (budget === 'entreprise' && si_exist === 'arcgis_si') score += 15;
  if (budget === 'entreprise' && si_exist === 'azure') score += 12;

  return score;
}

// Sélectionner le scénario avec le score le plus élevé
const scoredScenarios = SCENARIOS.map(sc => ({ sc, score: matchScore(sc) }));
scoredScenarios.sort((a, b) => b.score - a.score);
const SELECTED = scoredScenarios[0].sc;

/* ══════════════════════════════════════════════════════════════════
   CALCUL DU SCORE DE PERTINENCE
   Normalisé 55–97 selon la qualité du match
══════════════════════════════════════════════════════════════════ */
const maxPossible = 100; // 40 + 35 + 15 + 10
const rawScore = scoredScenarios[0].score;
const PCT = Math.min(97, Math.max(55, Math.round(55 + (rawScore / maxPossible) * 42)));

/* ══════════════════════════════════════════════════════════════════
   LABELS POUR L'AFFICHAGE
══════════════════════════════════════════════════════════════════ */
const SECTEUR_LABELS = {
  collectivite:"Collectivité Territoriale", etat:"État / Établissement public",
  geometre:"Géomètre-Expert", btp:"BTP / Infrastructures",
  bet_env:"BET Environnement", agriculture:"Agriculture / Agronomie",
  energie:"Énergie / Réseaux", transport:"Transport / Mobilité",
  bet:"Bureau d'Études", immobilier:"Immobilier / Foncier",
  geomarketing:"Géomarketing", ong:"Humanitaire / ONG",
  etudiant:"Étudiant / Recherche", ne_sait_pas:"Non précisé"
};
const BUDGET_LABELS = {
  zero:"0 € — Open Source", starter_free:"Starter < 500 €/an",
  inter_pro:"Intermédiaire 1 000–5 000 €/an", entreprise:"Enterprise +10 000 €/an",
  nsp:"Budget non précisé"
};

/* ══════════════════════════════════════════════════════════════════
   INJECTION META HERO
══════════════════════════════════════════════════════════════════ */
document.getElementById('heroTitle').textContent    = SELECTED.emoji + ' ' + SELECTED.name;
document.getElementById('heroSub').textContent      = SELECTED.desc;
document.getElementById('heroSecteur').textContent  = SECTEUR_LABELS[secteur] || 'Généraliste';
document.getElementById('heroBudget').textContent   = BUDGET_LABELS[budget] || 'Non précisé';
document.getElementById('heroMode').textContent     = mode === 'expert' ? 'Mode Expert' : 'Mode Standard';
document.getElementById('hdrBadge').textContent     = SELECTED.badge;
document.getElementById('scenarioBadge').textContent= SELECTED.badge;
document.getElementById('scenarioTitle').textContent= SELECTED.emoji + ' ' + SELECTED.name;
document.getElementById('scenarioDesc').textContent = SELECTED.desc;
document.getElementById('scoreNum').textContent     = PCT + '%';
document.getElementById('scoreFill').style.width    = PCT + '%';
document.getElementById('contactBtn').href          = `contact.html${window.location.search}&scenario=${SELECTED.id}`;

/* ══════════════════════════════════════════════════════════════════
   AFFICHAGE DES BRIQUES
   Cat map pour les classes CSS et labels
══════════════════════════════════════════════════════════════════ */
const CAT_CONFIG = {
  logiciels:   { cls:'cat-log', lbl:'Logiciel SIG', ico:'💻' },
  bases:       { cls:'cat-base', lbl:'Base de données spatiale', ico:'🗄️' },
  hebergement: { cls:'cat-srv', lbl:'Hébergement / Infrastructure', ico:'🖧' },
  publication: { cls:'cat-pub', lbl:'Publication Web & Portail', ico:'🌐' },
  imagerie:    { cls:'cat-ima', lbl:'Imagerie & Fond de plan', ico:'🛰️' },
  terrain:     { cls:'cat-ter', lbl:'Collecte Terrain', ico:'📱' }
};

const grid = document.getElementById('resultsGrid');
const budgetDetailEl = document.getElementById('budgetDetail');
let totalAnnuel = 0;

// Regrouper les logiciels multiples
const briquesGrouped = [];
let logGroup = null;
SELECTED.briques.forEach(b => {
  if (b.cat === 'logiciels') {
    if (!logGroup) {
      logGroup = { ...b, extra: [] };
      briquesGrouped.push(logGroup);
    } else {
      logGroup.extra.push(b);
    }
  } else {
    briquesGrouped.push(b);
  }
});

briquesGrouped.forEach((b, i) => {
  const d = DATA[b.cat]?.[b.key];
  if (!d) return;

  const cfg = CAT_CONFIG[b.cat] || { cls:'cat-log', lbl:b.cat, ico:'📦' };
  const prix = d.p;
  totalAnnuel += prix;

  const logoHtml = d.img
    ? `<img src="img/${d.img}" alt="${d.n}" style="width:38px;height:38px;object-fit:contain"
           onerror="this.style.display='none';this.nextSibling.style.display='flex'">
       <span class="ico" style="display:none">${cfg.ico}</span>`
    : `<span class="ico">${cfg.ico}</span>`;

  const priceStr = prix === 0 ? '✅ Gratuit / Open Source' : `${prix.toLocaleString('fr-FR')} € / an`;

  const links = [];
  if (d.link) links.push(`<a class="blink web" href="${d.link}" target="_blank" rel="noopener">🔗 Site</a>`);
  if (d.mail) links.push(`<a class="blink mail" href="mailto:${d.mail}">✉️ Contact</a>`);

  // Logiciels supplémentaires dans la même brique
  let extraHtml = '';
  if (b.extra && b.extra.length) {
    b.extra.forEach(ex => {
      const de = DATA[ex.cat]?.[ex.key];
      if (!de) return;
      totalAnnuel += de.p;
      extraHtml += `<div style="margin-top:8px;padding-top:8px;border-top:1px dashed var(--border);font-size:.78rem;color:var(--ink2)">
        <strong>+ ${de.n}</strong> <span style="color:var(--muted);font-size:.71rem">${de.sub}</span>
        <div style="font-size:.7rem;color:var(--muted);margin-top:2px">${de.d.substring(0,80)}…</div>
        <span style="font-family:'DM Mono',monospace;font-size:.7rem;color:${de.p===0?'var(--green)':'var(--amber)'}">${de.p===0?'Gratuit':de.p.toLocaleString('fr-FR')+' €/an'}</span>
      </div>`;
    });
  }

  grid.innerHTML += `
  <div class="brique ${cfg.cls}">
    ${i === 0 ? '<div class="winner-badge">⭐ Principal</div>' : ''}
    <div class="brique-top">
      <div class="brique-logo-wrap">${logoHtml}</div>
      <div class="brique-meta">
        <div class="brique-cat">${cfg.ico} ${cfg.lbl}</div>
        <div class="brique-name">${d.n}</div>
        ${d.sub ? `<div class="brique-sub">${d.sub}</div>` : ''}
      </div>
    </div>
    <div class="brique-body">${d.d}${extraHtml}</div>
    <div class="brique-foot">
      <span class="brique-price">${priceStr}</span>
      <div class="brique-links">${links.join('')}</div>
    </div>
  </div>`;

  budgetDetailEl.innerHTML += `
  <div class="bi">
    <span class="bi-lbl">${cfg.lbl}</span>
    <span class="bi-val">${prix === 0 ? 'Gratuit' : prix.toLocaleString('fr-FR') + ' €'}</span>
    ${b.note ? `<span class="bi-note">${b.note}</span>` : ''}
  </div>`;
});

// Extra logiciels dans le budget
if (logGroup && logGroup.extra) {
  logGroup.extra.forEach(ex => {
    const de = DATA[ex.cat]?.[ex.key];
    if (!de || de.p === 0) return;
    budgetDetailEl.innerHTML += `
    <div class="bi">
      <span class="bi-lbl">${de.n}</span>
      <span class="bi-val">${de.p.toLocaleString('fr-FR')} €</span>
      ${ex.note ? `<span class="bi-note">${ex.note}</span>` : ''}
    </div>`;
  });
}

document.getElementById('totalPrice').textContent = totalAnnuel.toLocaleString('fr-FR') + ' € / an';
document.getElementById('perUser').textContent = nbUsers > 1
  ? Math.round(totalAnnuel / nbUsers).toLocaleString('fr-FR') + ' € / utilisateur / an'
  : '—';

/* ══════════════════════════════════════════════════════════════════
   RAISONS — adaptées aux briques choisies (pas au profil)
══════════════════════════════════════════════════════════════════ */
const rl = document.getElementById('reasonsList');
SELECTED.reasons.forEach(r => {
  rl.innerHTML += `<div class="reason-item"><div class="rdot rdot-${r.dot}"></div><div>${r.txt}</div></div>`;
});

/* ══════════════════════════════════════════════════════════════════
   ALTERNATIVES — triées par proximité budgétaire
   "Similaire" si gratuit ou même fourchette
   "Budget sup." si supérieur
   "Hors budget" si très supérieur
══════════════════════════════════════════════════════════════════ */
const altContentEl = document.getElementById('altContent');

// Prix du scénario actuel pour référence
const winTotalPrice = totalAnnuel;

function budgetTag(p) {
  if (p === 0 || Math.abs(p - winTotalPrice) < 200) return '<span class="t-sim">Similaire</span>';
  if (p > winTotalPrice && p <= winTotalPrice * 3) return '<span class="t-sup">Budget sup.</span>';
  if (p > winTotalPrice * 3) return '<span class="t-hb">Hors budget</span>';
  return '<span class="t-sim">Similaire</span>';
}

function priceCls(p) { return p === 0 ? 'p-free' : p < 1000 ? 'p-paid' : 'p-big'; }
function priceLabel(p) { return p === 0 ? 'Gratuit' : p.toLocaleString('fr-FR') + ' €/an'; }

const ALT_LABELS = {
  logiciels:   { ico:'💻', label:'Logiciels SIG' },
  bases:       { ico:'🗄️', label:'Bases de données' },
  hebergement: { ico:'🖧', label:'Hébergement' },
  publication: { ico:'🌐', label:'Publication Web' },
  imagerie:    { ico:'🛰️', label:'Imagerie' },
  terrain:     { ico:'📱', label:'Collecte Terrain' }
};

if (SELECTED.alts) {
  Object.entries(SELECTED.alts).forEach(([cat, keys]) => {
    if (!keys || !keys.length) return;
    const cfg = ALT_LABELS[cat] || { ico:'📦', label:cat };
    const cards = keys.map(key => {
      const d = DATA[cat]?.[key];
      if (!d) return '';
      const logoEl = d.img
        ? `<img class="alt-logo" src="img/${d.img}" alt="${d.n}" onerror="this.style.display='none'">`
        : `<div class="alt-ico">${cfg.ico}</div>`;
      return `<div class="alt-card">${logoEl}
        <div class="alt-body">
          <div class="alt-name">${d.n}</div>
          <div class="alt-d">${d.d}</div>
          <div class="alt-foot">
            <span class="alt-p ${priceCls(d.p)}">${priceLabel(d.p)}</span>
            ${budgetTag(d.p)}
          </div>
        </div>
      </div>`;
    }).join('');

    if (cards) {
      altContentEl.innerHTML += `
      <div class="alt-group">
        <div class="alt-group-title">${cfg.ico} ${cfg.label}</div>
        <div class="alt-cards">${cards}</div>
      </div>`;
    }
  });
}
</script>
