<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Architecture SIG Préconisée — GeomarkSIG</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600;9..40,700&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root{
  --ink:#0f1923;--ink2:#2c3e50;--muted:#6b7a8d;--border:#dde3ec;--surface:#f5f7fa;--white:#fff;
  --green:#1a7a4a;--green-l:#e6f5ee;--blue:#1a56e8;--blue-l:#e8effd;
  --amber:#c9720c;--amber-l:#fef3e2;--red:#c0392b;--red-l:#fdf0ef;
  --purple:#6c3483;--purple-l:#f5eef8;--teal:#0e7490;--teal-l:#e0f2f7;
  --r:10px;--r2:16px;
}
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:'DM Sans',sans-serif;background:var(--surface);color:var(--ink);line-height:1.6}
a{color:var(--blue);text-decoration:none}a:hover{text-decoration:underline}
.page-header{background:var(--white);border-bottom:1px solid var(--border);position:sticky;top:0;z-index:100}
.header-inner{max-width:1180px;margin:auto;display:flex;align-items:center;justify-content:space-between;padding:14px 24px}
.logo-area{display:flex;align-items:center;gap:10px}
.logo-area img{height:40px;border-radius:6px}
.logo-text{font-weight:700;font-size:1rem;color:var(--green)}
.logo-sub{font-size:.7rem;color:var(--muted);display:block}
.header-badge{background:var(--green-l);color:var(--green);padding:5px 14px;border-radius:20px;font-size:.78rem;font-weight:600}
/* HERO */
.hero{background:linear-gradient(135deg,#0c1a10 0%,#0f2820 55%,#1a6040 100%);color:#fff;padding:48px 24px 40px;position:relative;overflow:hidden}
.hero::before{content:'';position:absolute;inset:0;background-image:radial-gradient(circle at 20% 80%,rgba(26,122,74,.15) 0%,transparent 50%),radial-gradient(circle at 80% 20%,rgba(26,86,232,.1) 0%,transparent 50%)}
.hero-inner{max-width:1180px;margin:auto;position:relative;display:grid;grid-template-columns:1fr auto;gap:32px;align-items:start}
.hero-tag{display:inline-block;background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.15);color:rgba(255,255,255,.9);font-size:.72rem;font-weight:600;letter-spacing:.6px;text-transform:uppercase;padding:4px 14px;border-radius:20px;margin-bottom:14px}
.hero h1{font-size:1.9rem;font-weight:700;margin-bottom:8px;line-height:1.2}
.hero-sub{font-size:.9rem;opacity:.72;max-width:540px;line-height:1.65;margin-bottom:18px}
.hero-meta{display:flex;gap:18px;flex-wrap:wrap}
.hm{font-size:.8rem;opacity:.75;display:flex;align-items:center;gap:5px}
.hm strong{opacity:1;font-weight:600}
/* Score pill */
.score-pill{background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.12);border-radius:12px;padding:18px 22px;text-align:center;min-width:130px;flex-shrink:0}
.score-big{font-family:'DM Mono',monospace;font-size:2.6rem;font-weight:500;color:#5be89e;line-height:1}
.score-lbl{font-size:.7rem;opacity:.6;margin-top:4px;text-transform:uppercase;letter-spacing:.5px}
.score-bar-wrap{margin-top:12px;width:100%;background:rgba(255,255,255,.12);height:4px;border-radius:2px;overflow:hidden}
.score-bar-fill{height:100%;background:linear-gradient(90deg,#2ecc71,#5be89e);border-radius:2px;transition:width .9s ease}
/* WRAP */
.wrap{max-width:1180px;margin:0 auto;padding:28px 24px 80px}
.slabel{font-size:.68rem;font-weight:700;text-transform:uppercase;letter-spacing:.8px;color:var(--muted);margin-bottom:12px;margin-top:26px;display:flex;align-items:center;gap:8px}
.slabel::after{content:'';flex:1;height:1px;background:var(--border)}
.scenario-name{font-size:1.3rem;font-weight:700;color:var(--ink);margin-bottom:4px}
.scenario-desc{color:var(--muted);font-size:.87rem;margin-bottom:20px;line-height:1.65}
/* Scénario badge */
.scenario-badge{display:inline-flex;align-items:center;gap:6px;font-size:.7rem;font-weight:700;text-transform:uppercase;letter-spacing:.5px;padding:3px 12px;border-radius:20px;margin-bottom:12px;background:var(--green-l);color:var(--green)}
/* BRIQUES */
.brique-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:14px;margin-bottom:8px}
.brique{background:var(--white);border:1.5px solid var(--border);border-radius:var(--r2);display:flex;flex-direction:column;transition:box-shadow .2s,border-color .2s;position:relative;overflow:hidden;animation:fadeUp .4s ease both}
.brique:nth-child(1){animation-delay:.04s}.brique:nth-child(2){animation-delay:.08s}.brique:nth-child(3){animation-delay:.12s}.brique:nth-child(4){animation-delay:.16s}.brique:nth-child(5){animation-delay:.20s}.brique:nth-child(6){animation-delay:.24s}.brique:nth-child(7){animation-delay:.28s}
@keyframes fadeUp{from{opacity:0;transform:translateY(14px)}to{opacity:1;transform:translateY(0)}}
.brique:hover{box-shadow:0 6px 24px rgba(0,0,0,.08);border-color:#b5c8e0}
.brique-top{display:flex;align-items:flex-start;gap:12px;padding:18px 18px 12px}
.brique-logo-wrap{flex-shrink:0;width:50px;height:50px;border-radius:10px;background:var(--surface);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;overflow:hidden}
.brique-logo-wrap img{width:38px;height:38px;object-fit:contain}
.brique-logo-wrap .ico{font-size:1.4rem}
.brique-meta{flex:1}
.brique-cat{font-size:.62rem;font-weight:700;text-transform:uppercase;letter-spacing:.7px;margin-bottom:2px}
.brique-name{font-size:.95rem;font-weight:700;color:var(--ink);line-height:1.2}
.brique-sub{font-size:.7rem;color:var(--muted);margin-top:2px}
.brique-body{font-size:.82rem;color:var(--muted);line-height:1.65;padding:0 18px 12px;flex:1}
.brique-foot{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:6px;padding:10px 18px;border-top:1px solid var(--border);background:var(--surface);margin-top:auto}
.brique-price{font-family:'DM Mono',monospace;font-size:.76rem;font-weight:500;padding:3px 9px;border-radius:6px}
.brique-links{display:flex;gap:5px;flex-wrap:wrap}
.blink{font-size:.7rem;font-weight:500;padding:3px 8px;border-radius:5px;transition:background .15s}
.blink.web{color:var(--blue);background:var(--blue-l)}.blink.web:hover{background:#c8d8fa;text-decoration:none}
.blink.mail{color:var(--green);background:var(--green-l)}.blink.mail:hover{background:#b8e8cc;text-decoration:none}
.winner-badge{position:absolute;top:10px;right:10px;background:var(--green);color:#fff;font-size:.58rem;font-weight:700;text-transform:uppercase;letter-spacing:.4px;padding:2px 7px;border-radius:8px}
/* Couleurs par catégorie */
.cat-log .brique-cat{color:var(--blue)} .cat-log .brique-price{background:var(--blue-l);color:var(--blue)} .cat-log{border-top:3px solid var(--blue)}
.cat-base .brique-cat{color:var(--purple)} .cat-base .brique-price{background:var(--purple-l);color:var(--purple)} .cat-base{border-top:3px solid var(--purple)}
.cat-srv .brique-cat{color:var(--teal)} .cat-srv .brique-price{background:var(--teal-l);color:var(--teal)} .cat-srv{border-top:3px solid var(--teal)}
.cat-pub .brique-cat{color:var(--green)} .cat-pub .brique-price{background:var(--green-l);color:var(--green)} .cat-pub{border-top:3px solid var(--green)}
.cat-ima .brique-cat{color:var(--amber)} .cat-ima .brique-price{background:var(--amber-l);color:var(--amber)} .cat-ima{border-top:3px solid var(--amber)}
.cat-ter .brique-cat{color:var(--red)} .cat-ter .brique-price{background:var(--red-l);color:var(--red)} .cat-ter{border-top:3px solid var(--red)}
/* BUDGET */
.budget-box{background:var(--white);border:1.5px solid var(--border);border-radius:var(--r2);padding:24px;margin-bottom:4px;border-left:4px solid var(--green)}
.budget-row{display:flex;justify-content:space-between;flex-wrap:wrap;gap:12px;margin-bottom:16px}
.budget-total{font-family:'DM Mono',monospace;font-size:2.2rem;font-weight:500;color:var(--green)}
.budget-per{font-family:'DM Mono',monospace;font-size:1rem;color:var(--ink2);text-align:right}
.budget-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(155px,1fr));gap:9px}
.bi{background:var(--surface);border-radius:8px;padding:10px 13px;display:flex;flex-direction:column;gap:2px}
.bi-lbl{font-size:.71rem;color:var(--muted)}.bi-val{font-family:'DM Mono',monospace;font-size:.82rem;font-weight:500;color:var(--ink)}
.bi-note{font-size:.65rem;color:var(--muted);line-height:1.4}
.budget-note{font-size:.71rem;color:var(--muted);margin-top:10px;line-height:1.5}
/* RAISONS */
.reasons-box{background:var(--white);border:1.5px solid var(--border);border-radius:var(--r2);padding:22px;margin-bottom:4px}
.reason-item{display:flex;gap:9px;align-items:flex-start;padding:9px 11px;border-radius:8px;background:var(--surface);font-size:.82rem;color:var(--ink2);line-height:1.65;margin-bottom:7px}
.reason-item:last-child{margin-bottom:0}
.rdot{width:7px;height:7px;border-radius:50%;margin-top:7px;flex-shrink:0}
.rdot-g{background:var(--green)}.rdot-a{background:var(--amber)}.rdot-b{background:var(--blue)}.rdot-r{background:var(--red)}
/* ALT */
.alt-box{background:var(--white);border:1.5px solid var(--border);border-radius:var(--r2);padding:22px;margin-bottom:4px}
.alt-intro{font-size:.82rem;color:var(--muted);margin-bottom:16px;line-height:1.65}
.alt-group{margin-bottom:20px}.alt-group:last-child{margin-bottom:0}
.alt-group-title{font-size:.7rem;font-weight:700;text-transform:uppercase;letter-spacing:.6px;color:var(--muted);margin-bottom:9px;padding-bottom:6px;border-bottom:1px solid var(--border)}
.alt-cards{display:flex;flex-wrap:wrap;gap:8px}
.alt-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--r);padding:11px 13px;display:flex;align-items:flex-start;gap:9px;flex:1;min-width:190px;max-width:300px;transition:border-color .15s}
.alt-card:hover{border-color:#b5c8e0}
.alt-logo{width:28px;height:28px;object-fit:contain;background:#fff;border:1px solid var(--border);border-radius:5px;padding:3px;flex-shrink:0}
.alt-ico{width:28px;height:28px;background:#fff;border:1px solid var(--border);border-radius:5px;display:flex;align-items:center;justify-content:center;font-size:.9rem;flex-shrink:0}
.alt-body{flex:1;min-width:0}
.alt-name{font-size:.8rem;font-weight:600;color:var(--ink);margin-bottom:2px}
.alt-d{font-size:.71rem;color:var(--muted);line-height:1.45}
.alt-foot{display:flex;align-items:center;justify-content:space-between;margin-top:5px;flex-wrap:wrap;gap:3px}
.alt-p{font-family:'DM Mono',monospace;font-size:.67rem;font-weight:500}
.p-free{color:var(--green)}.p-paid{color:var(--amber)}.p-big{color:var(--red)}
.t-sim{font-size:.6rem;font-weight:700;text-transform:uppercase;background:var(--green-l);color:var(--green);padding:1px 5px;border-radius:3px}
.t-sup{font-size:.6rem;font-weight:700;text-transform:uppercase;background:var(--blue-l);color:var(--blue);padding:1px 5px;border-radius:3px}
.t-hb{font-size:.6rem;font-weight:700;text-transform:uppercase;background:var(--amber-l);color:var(--amber);padding:1px 5px;border-radius:3px}
/* ACTIONS */
.actions{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:4px}
.btn{padding:12px 20px;border-radius:var(--r);font-size:.87rem;font-weight:600;cursor:pointer;transition:all .15s;text-decoration:none;display:inline-flex;align-items:center;gap:6px;border:none;font-family:'DM Sans',sans-serif}
.btn-primary{background:var(--green);color:#fff;box-shadow:0 2px 12px rgba(26,122,74,.2)}.btn-primary:hover{background:#15643d;text-decoration:none;color:#fff}
.btn-outline{background:#fff;color:var(--ink);border:1.5px solid var(--border)}.btn-outline:hover{border-color:#a0b4cc;text-decoration:none;color:var(--ink)}
.btn-amber{background:var(--amber-l);color:var(--amber);border:1.5px solid #f0c070}.btn-amber:hover{background:#fde8b8;text-decoration:none;color:var(--amber)}
/* FOOTER */
.page-footer{border-top:1px solid var(--border);padding:16px 24px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;background:var(--white)}
.footer-right img{height:30px;opacity:.5}
.footer-note{font-size:.71rem;color:var(--muted)}
@media(max-width:640px){.hero-inner{grid-template-columns:1fr}.score-pill{display:none}.hero h1{font-size:1.4rem}.budget-total{font-size:1.7rem}.brique-grid{grid-template-columns:1fr}.actions{flex-direction:column}}
@media print{.page-header,.actions,.page-footer{display:none}.hero{print-color-adjust:exact;-webkit-print-color-adjust:exact}}
</style>
</head>
